<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal: fondo negro, sin ActionBar -->
    <style name="Theme.BetterGFN" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Tema splash: fondo oscuro, sin ActionBar -->
    <style name="Theme.Splash" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#0d1117</item>
        <item name="android:statusBarColor">#0d1117</item>
        <item name="android:navigationBarColor">#0d1117</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
